# Frontend endpoint (optional)
# Use this if your API is hosted on another domain.
# If omitted, frontend defaults to /api/enquiry.
VITE_ENQUIRY_API_URL=

# SMTP settings for api/enquiry.ts
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Sender and recipient
SMTP_FROM=Bluechilli AI <hello@bluechilli.ai>
ENQUIRY_TO=hello@bluechilli.ai
